diff --git a/src/zen/tests/spaces/browser_workspace_icon_url.js b/src/zen/tests/spaces/browser_workspace_icon_url.js
new file mode 100644
index 0000000..2c0c82c
--- /dev/null
+++ b/src/zen/tests/spaces/browser_workspace_icon_url.js
@@ -0,0 +1,87 @@
+/* Any copyright is dedicated to the Public Domain.
+   https://creativecommons.org/publicdomain/zero/1.0/ */
+
+"use strict";
+
+function mockPrompt(value) {
+  const original = Services.prompt;
+  Services.prompt = {
+    QueryInterface: ChromeUtils.generateQI([Ci.nsIPromptService]),
+    prompt(win, title, label, result) {
+      if (value === null) {
+        return false;
+      }
+      result.value = value;
+      return true;
+    },
+  };
+  return () => {
+    Services.prompt = original;
+  };
+}
+
+add_task(async function test_SetWorkspaceIconURL() {
+  const workspace = gZenWorkspaces.getActiveWorkspace();
+  const originalIcon = workspace.icon;
+  const iconURL =
+    "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg'/%3E";
+  const restorePrompt = mockPrompt(iconURL);
+
+  try {
+    await gZenWorkspaces.setWorkspaceIconURL();
+
+    Assert.equal(
+      gZenWorkspaces.getWorkspaceFromId(workspace.uuid).icon,
+      iconURL,
+      "The workspace icon should be updated to the entered image URL"
+    );
+    Assert.ok(
+      gZenWorkspaces.isWorkspaceImageIcon(iconURL),
+      "The entered URL should be treated as an image icon"
+    );
+  } finally {
+    restorePrompt();
+    workspace.icon = originalIcon;
+    gZenWorkspaces.saveWorkspace(workspace);
+  }
+});
+
+add_task(async function test_SetWorkspaceIconURLRejectsInvalidURL() {
+  const workspace = gZenWorkspaces.getActiveWorkspace();
+  const originalIcon = workspace.icon;
+  const restorePrompt = mockPrompt("not-an-image-url");
+
+  try {
+    await gZenWorkspaces.setWorkspaceIconURL();
+
+    Assert.equal(
+      gZenWorkspaces.getWorkspaceFromId(workspace.uuid).icon,
+      originalIcon,
+      "Invalid image URLs should not overwrite the existing workspace icon"
+    );
+  } finally {
+    restorePrompt();
+  }
+});
+
+add_task(async function test_SetWorkspaceIconURLCanClearIcon() {
+  const workspace = gZenWorkspaces.getActiveWorkspace();
+  const originalIcon = workspace.icon;
+  workspace.icon = "https://example.com/icon.png";
+  gZenWorkspaces.saveWorkspace(workspace);
+  const restorePrompt = mockPrompt("");
+
+  try {
+    await gZenWorkspaces.setWorkspaceIconURL();
+
+    Assert.equal(
+      gZenWorkspaces.getWorkspaceFromId(workspace.uuid).icon,
+      "",
+      "Empty input should clear the custom workspace icon"
+    );
+  } finally {
+    restorePrompt();
+    workspace.icon = originalIcon;
+    gZenWorkspaces.saveWorkspace(workspace);
+  }
+});
